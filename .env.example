# Cloud features (auth, save/load, sharing) are optional. Without these set,
# Accel runs in local-only mode: no accounts, nothing persists across reloads.
#
# To enable them:
#   1. Create a free project at https://supabase.com
#   2. Run supabase/schema.sql in that project's SQL editor
#   3. Copy the Project URL and anon/public API key from Project Settings > API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
