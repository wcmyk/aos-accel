# Radix configuration — copy this file to `.env` and fill in what you need.
# EVERY variable below is OPTIONAL. With none set, Radix runs fully in
# local-only mode using built-in offline fallbacks.
#
# ---------------------------------------------------------------------------
# Cloud features (auth, save/load, sharing) are optional. Without these set,
# Radix runs in local-only mode: no accounts, nothing persists across reloads.
#
# To enable them:
#   1. Create a free project at https://supabase.com
#   2. Run supabase/schema.sql in that project's SQL editor
#   3. Copy the Project URL and anon/public API key from Project Settings > API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Live market data for the STOCK() formula (optional).
# Get a free API key at https://polygon.io — without one, STOCK() falls back
# to deterministic synthetic demo data so the feature still works offline.
# NEVER commit your real key; .env is gitignored for a reason.
VITE_STOCK_API_KEY=
